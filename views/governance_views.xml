<odoo>
    <data>

        <!-- ============ ESG POLICY ============ -->
        <record id="view_eco_policy_tree" model="ir.ui.view">
            <field name="name">eco.policy.tree</field>
            <field name="model">eco.policy</field>
            <field name="arch" type="xml">
                <tree decoration-muted="state == 'archived'" decoration-info="state == 'draft'">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="category"/>
                    <field name="version"/>
                    <field name="effective_date"/>
                    <field name="acknowledgement_rate" widget="percentage"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'active'"
                           decoration-danger="state == 'archived'"/>
                </tree>
            </field>
        </record>

        <record id="view_eco_policy_form" model="ir.ui.view">
            <field name="name">eco.policy.form</field>
            <field name="model">eco.policy</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_activate" string="Activate" type="object"
                                class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_archive_policy" string="Archive" type="object"
                                invisible="state != 'active'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,active,archived"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" placeholder="Policy Name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="code"/>
                                <field name="category"/>
                                <field name="version"/>
                                <field name="effective_date"/>
                            </group>
                            <group>
                                <field name="department_ids" widget="many2many_tags"/>
                                <field name="acknowledgement_count"/>
                                <field name="acknowledgement_rate" widget="percentage"/>
                            </group>
                        </group>
                        <group string="Document">
                            <field name="document" filename="document_filename"/>
                            <field name="document_filename" invisible="1"/>
                        </group>
                        <notebook>
                            <page string="Description">
                                <field name="description"/>
                            </page>
                            <page string="Acknowledgements">
                                <field name="acknowledgement_ids">
                                    <tree editable="bottom">
                                        <field name="employee_id"/>
                                        <field name="department_id"/>
                                        <field name="state" widget="badge"
                                               decoration-success="state == 'acknowledged'"
                                               decoration-danger="state == 'overdue'"/>
                                        <field name="due_date"/>
                                        <field name="acknowledged_date"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="action_eco_policy" model="ir.actions.act_window">
            <field name="name">Policies</field>
            <field name="res_model">eco.policy</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html"><p class="o_view_nocontent_smiling_face">Create your first ESG policy</p></field>
        </record>

        <!-- ============ POLICY ACKNOWLEDGEMENT ============ -->
        <record id="view_eco_policy_acknowledgement_tree" model="ir.ui.view">
            <field name="name">eco.policy.acknowledgement.tree</field>
            <field name="model">eco.policy.acknowledgement</field>
            <field name="arch" type="xml">
                <tree decoration-danger="state == 'overdue'" decoration-success="state == 'acknowledged'">
                    <field name="policy_id"/>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <field name="due_date"/>
                    <field name="state" widget="badge"/>
                    <field name="reminder_sent_count"/>
                    <button name="action_acknowledge" string="Acknowledge" type="object"
                            invisible="state == 'acknowledged'" class="oe_highlight"/>
                    <button name="action_send_reminder" string="Send Reminder" type="object"
                            invisible="state == 'acknowledged'"/>
                </tree>
            </field>
        </record>

        <record id="view_eco_policy_acknowledgement_search" model="ir.ui.view">
            <field name="name">eco.policy.acknowledgement.search</field>
            <field name="model">eco.policy.acknowledgement</field>
            <field name="arch" type="xml">
                <search>
                    <field name="policy_id"/>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <filter string="Pending" name="pending" domain="[('state','=','pending')]"/>
                    <filter string="Overdue" name="overdue" domain="[('state','=','overdue')]"/>
                    <filter string="Acknowledged" name="acknowledged" domain="[('state','=','acknowledged')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                        <filter string="Policy" name="group_policy" context="{'group_by': 'policy_id'}"/>
                        <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_eco_policy_acknowledgement" model="ir.actions.act_window">
            <field name="name">Policy Acknowledgements</field>
            <field name="res_model">eco.policy.acknowledgement</field>
            <field name="view_mode">tree</field>
        </record>

        <!-- ============ AUDIT ============ -->
        <record id="view_eco_audit_tree" model="ir.ui.view">
            <field name="name">eco.audit.tree</field>
            <field name="model">eco.audit</field>
            <field name="arch" type="xml">
                <tree decoration-danger="open_issue_count > 0">
                    <field name="name"/>
                    <field name="title"/>
                    <field name="department_id"/>
                    <field name="auditor_id"/>
                    <field name="date"/>
                    <field name="open_issue_count"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'completed'"
                           decoration-info="state == 'under_review'"/>
                </tree>
            </field>
        </record>

        <record id="view_eco_audit_form" model="ir.ui.view">
            <field name="name">eco.audit.form</field>
            <field name="model">eco.audit</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_start" string="Start Audit" type="object"
                                invisible="state != 'planned'" class="oe_highlight"/>
                        <button name="action_submit_for_review" string="Submit for Review" type="object"
                                invisible="state != 'in_progress'" class="oe_highlight"/>
                        <button name="action_complete" string="Mark Completed" type="object"
                                invisible="state != 'under_review'" class="oe_highlight"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="planned,in_progress,under_review,completed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="title"/>
                            <h1><field name="title" placeholder="Audit Title"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="department_id"/>
                                <field name="auditor_id"/>
                                <field name="audit_type"/>
                                <field name="date"/>
                            </group>
                            <group>
                                <field name="issue_count"/>
                                <field name="open_issue_count"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Scope">
                                <field name="scope"/>
                            </page>
                            <page string="Findings">
                                <field name="findings"/>
                            </page>
                            <page string="Compliance Issues">
                                <field name="compliance_issue_ids">
                                    <tree editable="bottom" decoration-danger="status == 'open'">
                                        <field name="description"/>
                                        <field name="severity"/>
                                        <field name="owner_id"/>
                                        <field name="due_date"/>
                                        <field name="status" widget="badge"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="action_eco_audit" model="ir.actions.act_window">
            <field name="name">Audits</field>
            <field name="res_model">eco.audit</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html"><p class="o_view_nocontent_smiling_face">Schedule your first audit</p></field>
        </record>

        <!-- ============ COMPLIANCE ISSUE ============ -->
        <record id="view_eco_compliance_issue_tree" model="ir.ui.view">
            <field name="name">eco.compliance.issue.tree</field>
            <field name="model">eco.compliance.issue</field>
            <field name="arch" type="xml">
                <tree decoration-danger="is_overdue" decoration-warning="severity in ('high','critical') and not is_overdue">
                    <field name="name"/>
                    <field name="audit_id"/>
                    <field name="department_id"/>
                    <field name="description"/>
                    <field name="severity" widget="badge"
                           decoration-danger="severity == 'critical'"
                           decoration-warning="severity == 'high'"/>
                    <field name="owner_id"/>
                    <field name="due_date"/>
                    <field name="is_overdue"/>
                    <field name="status" widget="badge" decoration-success="status == 'resolved'"/>
                </tree>
            </field>
        </record>

        <record id="view_eco_compliance_issue_form" model="ir.ui.view">
            <field name="name">eco.compliance.issue.form</field>
            <field name="model">eco.compliance.issue</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_start_progress" string="Start Progress" type="object"
                                invisible="status != 'open'" class="oe_highlight"/>
                        <button name="action_resolve" string="Resolve" type="object"
                                invisible="status == 'resolved'" class="oe_highlight"/>
                        <field name="status" widget="statusbar" statusbar_visible="open,in_progress,resolved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="audit_id"/>
                                <field name="department_id" readonly="1"/>
                                <field name="severity"/>
                                <field name="is_overdue"/>
                            </group>
                            <group>
                                <field name="owner_id"/>
                                <field name="due_date"/>
                            </group>
                        </group>
                        <group string="Description">
                            <field name="description" nolabel="1"/>
                        </group>
                        <group string="Resolution" invisible="status != 'resolved'">
                            <field name="resolution_notes" nolabel="1"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_eco_compliance_issue_search" model="ir.ui.view">
            <field name="name">eco.compliance.issue.search</field>
            <field name="model">eco.compliance.issue</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="owner_id"/>
                    <filter string="Open" name="open" domain="[('status','=','open')]"/>
                    <filter string="Overdue" name="overdue" domain="[('is_overdue','=',True)]"/>
                    <filter string="Critical/High" name="severe" domain="[('severity','in',['high','critical'])]"/>
                    <group expand="0" string="Group By">
                        <filter string="Department" name="group_dept" context="{'group_by': 'department_id'}"/>
                        <filter string="Severity" name="group_sev" context="{'group_by': 'severity'}"/>
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_eco_compliance_issue" model="ir.actions.act_window">
            <field name="name">Compliance Issues</field>
            <field name="res_model">eco.compliance.issue</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- ============ DEPARTMENT SCORE (read-only, engine output) ============ -->
        <record id="view_eco_department_score_tree" model="ir.ui.view">
            <field name="name">eco.department.score.tree</field>
            <field name="model">eco.department.score</field>
            <field name="arch" type="xml">
                <tree create="false" edit="false">
                    <field name="department_id"/>
                    <field name="period_date"/>
                    <field name="environmental_score" widget="percentage"/>
                    <field name="social_score" widget="percentage"/>
                    <field name="governance_score" widget="percentage"/>
                    <field name="total_score" widget="percentage"/>
                </tree>
            </field>
        </record>

        <record id="action_eco_department_score" model="ir.actions.act_window">
            <field name="name">Department Scores</field>
            <field name="res_model">eco.department.score</field>
            <field name="view_mode">tree</field>
        </record>

        <!-- ============ MENU ITEMS (children of menu_eco_governance from menu_views.xml) ============ -->
        <menuitem id="menu_eco_policy" name="Policies" parent="menu_eco_governance"
                  action="action_eco_policy" sequence="10"/>
        <menuitem id="menu_eco_policy_acknowledgement" name="Policy Acknowledgements" parent="menu_eco_governance"
                  action="action_eco_policy_acknowledgement" sequence="20"/>
        <menuitem id="menu_eco_audit" name="Audits" parent="menu_eco_governance"
                  action="action_eco_audit" sequence="30"/>
        <menuitem id="menu_eco_compliance_issue" name="Compliance Issues" parent="menu_eco_governance"
                  action="action_eco_compliance_issue" sequence="40"/>
        <menuitem id="menu_eco_department_score" name="Department Scores" parent="menu_eco_governance"
                  action="action_eco_department_score" sequence="50"/>

    </data>
</odoo>