<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================== -->
    <!-- ECO.CHALLENGE VIEWS                            -->
    <!-- ============================================== -->
    <record id="view_eco_challenge_form" model="ir.ui.view">
        <field name="name">esg.challenge.form</field>
        <field name="model">esg.challenge</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" string="Activate" type="object" class="oe_highlight" invisible="status != 'draft'"/>
                    <button name="action_submit" string="Submit for Review" type="object" class="oe_highlight" invisible="status != 'active'"/>
                    <button name="action_complete" string="Complete" type="object" class="oe_highlight" invisible="status != 'under_review'"/>
                    <button name="action_archive" string="Archive" type="object" invisible="status in ('archived', 'completed')"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,active,review,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Challenge Title"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="difficulty"/>
                            <field name="xp_reward"/>
                            <field name="dynamic_xp" readonly="1" force_save="1"/>
                        </group>
                        <group>
                            <field name="deadline"/>
                            <field name="department_id"/>
                            <field name="completion_rate" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="AI Settings">
                            <group>
                                <field name="ai_generated" readonly="1"/>
                                <field name="ai_rationale" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_eco_challenge_tree" model="ir.ui.view">
        <field name="name">esg.challenge.tree</field>
        <field name="model">esg.challenge</field>
        <field name="arch" type="xml">
            <tree string="Challenges">
                <header>
                    <button name="action_ai_generate" string="AI Generate Challenges" type="object" class="btn-primary"/>
                </header>
                <field name="name"/>
                <field name="difficulty"/>
                <field name="dynamic_xp"/>
                <field name="deadline"/>
                <field name="status" widget="badge" decoration-info="status == 'draft'" decoration-success="status == 'active'" decoration-warning="status == 'review'" decoration-muted="status == 'completed'"/>
            </tree>
        </field>
    </record>

    <record id="view_eco_challenge_kanban" model="ir.ui.view">
        <field name="name">esg.challenge.kanban</field>
        <field name="model">esg.challenge</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_mobile">
                <field name="name"/>
                <field name="difficulty"/>
                <field name="dynamic_xp"/>
                <field name="completion_rate"/>
                <field name="status"/>
                <field name="ai_rationale"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="mt4">
                                    <span class="badge rounded-pill text-bg-info">
                                        XP: <field name="dynamic_xp"/>
                                    </span>
                                    <span class="badge rounded-pill text-bg-warning ms-1">
                                        Difficulty: <field name="difficulty"/>
                                    </span>
                                    <t t-if="record.ai_rationale.raw_value">
                                        <span class="fa fa-robot ms-2 text-info" t-att-title="record.ai_rationale.raw_value" role="img" aria-label="AI Rationale"></span>
                                    </t>
                                </div>
                                <div class="mt-2">
                                    <field name="completion_rate" widget="progressbar"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================== -->
    <!-- ECO.CHALLENGE.PARTICIPATION VIEWS              -->
    <!-- ============================================== -->
    <record id="view_eco_challenge_participation_form" model="ir.ui.view">
        <field name="name">esg.challenge.participation.form</field>
        <field name="model">esg.challenge.participation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit_proof" string="Submit Proof" type="object" class="oe_highlight" invisible="approval_status != 'pending'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="approval_status != 'pending'"/>
                    <button name="action_reject" string="Reject" type="object" invisible="approval_status != 'pending'"/>
                    <field name="approval_status" widget="statusbar" statusbar_visible="pending,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="challenge_id"/>
                            <field name="employee_id"/>
                            <field name="progress" widget="progressbar"/>
                            <field name="xp_awarded"/>
                        </group>
                        <group>
                            <field name="proof" filename="proof_filename"/>
                            <field name="proof_filename" invisible="1"/>
                            <field name="started_date"/>
                            <field name="submitted_date"/>
                            <field name="completion_date"/>
                            <field name="days_to_complete"/>
                            <field name="attempt_number"/>
                            <field name="engagement_score" widget="progressbar"/>
                            <field name="sentiment_tag"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="AI Feedback">
                            <field name="ai_feedback"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_eco_challenge_participation_tree" model="ir.ui.view">
        <field name="name">esg.challenge.participation.tree</field>
        <field name="model">esg.challenge.participation</field>
        <field name="arch" type="xml">
            <tree string="Participations">
                <field name="challenge_id"/>
                <field name="employee_id"/>
                <field name="started_date"/>
                <field name="progress" widget="progressbar"/>
                <field name="xp_awarded"/>
                <field name="approval_status" widget="badge" decoration-success="approval_status == 'approved'" decoration-danger="approval_status == 'rejected'" decoration-warning="approval_status == 'pending'"/>
            </tree>
        </field>
    </record>

    <!-- ============================================== -->
    <!-- ECO.BADGE VIEWS                                -->
    <!-- ============================================== -->
    <record id="view_eco_badge_kanban" model="ir.ui.view">
        <field name="name">esg.badge.kanban</field>
        <field name="model">esg.badge</field>
        <field name="arch" type="xml">
            <kanban default_group_by="badge_family_id">
                <field name="name"/>
                <field name="description"/>
                <field name="icon"/>
                <field name="rarity"/>
                <field name="badge_family_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div><field name="description"/></div>
                                <div class="mt-2">
                                    <span t-attf-class="badge rounded-pill #{record.rarity.raw_value == 'legendary' ? 'text-bg-warning' : (record.rarity.raw_value == 'epic' ? 'text-bg-danger' : (record.rarity.raw_value == 'rare' ? 'text-bg-primary' : 'text-bg-secondary'))}">
                                        <field name="rarity"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <record id="view_eco_badge_form" model="ir.ui.view">
        <field name="name">esg.badge.form</field>
        <field name="model">esg.badge</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Badge Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="description"/>
                            <field name="icon"/>
                            <field name="badge_family_id"/>
                            <field name="rarity"/>
                        </group>
                        <group>
                            <field name="unlock_rule"/>
                            <field name="unlock_value"/>
                            <field name="auto_expiry"/>
                            <field name="expiry_days" invisible="auto_expiry == False"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================== -->
    <!-- ECO.REWARD VIEWS                               -->
    <!-- ============================================== -->
    <record id="view_eco_reward_tree" model="ir.ui.view">
        <field name="name">esg.reward.tree</field>
        <field name="model">esg.reward</field>
        <field name="arch" type="xml">
            <tree string="Rewards" default_order="status asc, points_required asc">
                <field name="name"/>
                <field name="reward_category"/>
                <field name="points_required"/>
                <field name="stock"/>
                <field name="popularity_score" widget="progressbar"/>
                <field name="status" widget="badge" decoration-success="status == 'available'" decoration-danger="status == 'out_of_stock'"/>
            </tree>
        </field>
    </record>
    
    <record id="view_eco_reward_form" model="ir.ui.view">
        <field name="name">esg.reward.form</field>
        <field name="model">esg.reward</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_redeem" string="Redeem Reward" type="object" class="oe_highlight" invisible="status != 'available'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Reward Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="description"/>
                            <field name="reward_category"/>
                            <field name="points_required"/>
                            <field name="stock"/>
                        </group>
                        <group>
                            <field name="target_sentiment"/>
                            <field name="discount_for_streak"/>
                            <field name="popularity_score" widget="progressbar"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================== -->
    <!-- ACTIONS AND MENUS                              -->
    <!-- ============================================== -->
    <record id="action_eco_challenge" model="ir.actions.act_window">
        <field name="name">Challenges</field>
        <field name="res_model">esg.challenge</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <record id="action_eco_challenge_participation" model="ir.actions.act_window">
        <field name="name">Challenge Participations</field>
        <field name="res_model">esg.challenge.participation</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_eco_badge" model="ir.actions.act_window">
        <field name="name">Badges</field>
        <field name="res_model">esg.badge</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <record id="action_eco_reward" model="ir.actions.act_window">
        <field name="name">Rewards</field>
        <field name="res_model">esg.reward</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_eco_challenge" name="Challenges" parent="menu_eco_gamification" action="action_eco_challenge" sequence="10"/>
    <menuitem id="menu_eco_challenge_part" name="Participations" parent="menu_eco_gamification" action="action_eco_challenge_participation" sequence="20"/>
    <menuitem id="menu_eco_badge" name="Badges" parent="menu_eco_gamification" action="action_eco_badge" sequence="30"/>
    <menuitem id="menu_eco_reward" name="Rewards" parent="menu_eco_gamification" action="action_eco_reward" sequence="40"/>

</odoo>
