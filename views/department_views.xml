<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_eco_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">eco.department</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_eco_department_tree" model="ir.ui.view">
        <field name="name">eco.department.tree</field>
        <field name="model">eco.department</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="score"/>
            </tree>
        </field>
    </record>

    <record id="view_eco_department_form" model="ir.ui.view">
        <field name="name">eco.department.form</field>
        <field name="model">eco.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="manager_id"/>
                        <field name="category_ids"/>
                        <field name="score"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_eco_department_menu" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">eco.department</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_eco_departments" name="Departments" parent="menu_eco_root" action="action_eco_department_menu" sequence="1"/>
</odoo>
