<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_eco_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">esg.department</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <record id="view_eco_department_kanban" model="ir.ui.view">
        <field name="name">esg.department.kanban</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_ecosphere_kanban">
                <field name="name"/>
                <field name="code"/>
                <field name="head_id"/>
                <field name="parent_id"/>
                <field name="employee_count"/>
                <field name="status"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_ecosphere_kpi_card">
                            <div class="o_ecosphere_card_header">
                                <strong><field name="name"/></strong>
                                <field name="status" widget="badge"
                                       decoration-success="status == 'active'"
                                       decoration-muted="status == 'inactive'"/>
                            </div>
                            <div class="text-muted">
                                <field name="code"/>
                            </div>
                            <div class="o_ecosphere_metric_row">
                                <div>
                                    <span class="o_ecosphere_metric_value"><field name="employee_count"/></span>
                                    <span class="o_ecosphere_metric_label">Employees</span>
                                </div>
                                <div>
                                    <span class="o_ecosphere_metric_value"><field name="head_id"/></span>
                                    <span class="o_ecosphere_metric_label">Head</span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_eco_department_tree" model="ir.ui.view">
        <field name="name">esg.department.tree</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <tree decoration-muted="status == 'inactive'">
                <field name="name"/>
                <field name="code"/>
                <field name="head_id"/>
                <field name="parent_id"/>
                <field name="employee_count" sum="Employees"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-muted="status == 'inactive'"/>
            </tree>
        </field>
    </record>

    <record id="view_eco_department_form" model="ir.ui.view">
        <field name="name">esg.department.form</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <form string="Department">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Department name"/></h1>
                    </div>
                    <group>
                        <group string="Ownership">
                            <field name="code"/>
                            <field name="head_id"/>
                            <field name="parent_id"/>
                        </group>
                        <group string="Status">
                            <field name="employee_count"/>
                            <field name="status" widget="radio"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_eco_department_search" model="ir.ui.view">
        <field name="name">esg.department.search</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="head_id"/>
                <filter string="Active" name="active" domain="[('status','=','active')]"/>
                <filter string="Inactive" name="inactive" domain="[('status','=','inactive')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Parent Department" name="group_parent" context="{'group_by': 'parent_id'}"/>
                    <filter string="Head" name="group_head" context="{'group_by': 'head_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_eco_department_menu" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">esg.department</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_eco_department_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <menuitem id="menu_eco_departments" name="Departments" parent="menu_eco_root" action="action_eco_department_menu" sequence="1"/>
</odoo>
