<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_eco_dashboard_kanban" model="ir.ui.view">
        <field name="name">esg.dashboard.kanban</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <kanban class="o_ecosphere_dashboard" create="false" default_group_by="status">
                <field name="name"/>
                <field name="code"/>
                <field name="head_id"/>
                <field name="employee_count"/>
                <field name="status"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_ecosphere_kpi_card">
                            <div class="o_ecosphere_card_header">
                                <div>
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    <div class="text-muted">
                                        <field name="code"/>
                                    </div>
                                </div>
                                <field name="status" widget="badge"
                                       decoration-success="status == 'active'"
                                       decoration-muted="status == 'inactive'"/>
                            </div>
                            <div class="o_ecosphere_metric_row">
                                <div>
                                    <span class="o_ecosphere_metric_value"><field name="employee_count"/></span>
                                    <span class="o_ecosphere_metric_label">Employees</span>
                                </div>
                                <div>
                                    <span class="o_ecosphere_metric_value"><field name="head_id"/></span>
                                    <span class="o_ecosphere_metric_label">Department Head</span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_eco_dashboard_form" model="ir.ui.view">
        <field name="name">esg.dashboard.form</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <form string="ESG Dashboard">
                <sheet>
                    <group>
                        <h1>EcoSphere ESG Dashboard</h1>
                        <div class="o_row">
                            <div class="o_col">
                                <field name="name" readonly="1"/>
                                <field name="status" readonly="1"/>
                            </div>
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_eco_dashboard_search" model="ir.ui.view">
        <field name="name">esg.dashboard.search</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="head_id"/>
                <filter string="Active" name="active_departments" domain="[('status','=','active')]"/>
                <filter string="Inactive" name="inactive_departments" domain="[('status','=','inactive')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Parent Department" name="group_parent" context="{'group_by': 'parent_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_eco_dashboard" model="ir.actions.act_window">
        <field name="name">Executive Dashboard</field>
        <field name="res_model">esg.department</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_eco_dashboard_search"/>
        <field name="context">{'search_default_active_departments': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create departments to start building the ESG dashboard.</p>
        </field>
    </record>

    <menuitem id="menu_eco_dashboard" name="Dashboard" parent="menu_eco_root"
              action="action_eco_dashboard" sequence="0"/>
</odoo>
