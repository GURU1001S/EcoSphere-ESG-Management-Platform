<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Eco Warrior: Awarded for 5 Challenges -->
        <record id="badge_eco_warrior" model="esg.badge">
            <field name="name">Eco Warrior</field>
            <field name="description">Awarded for completing 5 Environmental Challenges.</field>
            <field name="unlock_rule">challenge_count</field>
            <field name="unlock_value">5</field>
            <field name="rarity">rare</field>
        </record>

        <!-- ESG Master: Awarded for 1000 XP -->
        <record id="badge_xp_master" model="esg.badge">
            <field name="name">ESG Master</field>
            <field name="description">Awarded for reaching 1000 total XP across all ESG activities.</field>
            <field name="unlock_rule">xp_threshold</field>
            <field name="unlock_value">1000</field>
            <field name="rarity">epic</field>
        </record>

        <record id="badge_streak_builder" model="esg.badge">
            <field name="name">Streak Builder</field>
            <field name="description">Awarded for staying active for 3 consecutive weeks.</field>
            <field name="unlock_rule">streak</field>
            <field name="unlock_value">3</field>
            <field name="rarity">common</field>
        </record>

        <record id="badge_impact_star" model="esg.badge">
            <field name="name">Impact Star</field>
            <field name="description">Awarded for maintaining a strong average CSR impact score.</field>
            <field name="unlock_rule">impact_score_avg</field>
            <field name="unlock_value">8</field>
            <field name="rarity">rare</field>
        </record>

        <record id="badge_department_champion" model="esg.badge">
            <field name="name">Department Champion</field>
            <field name="description">Awarded to the top XP contributor in a department.</field>
            <field name="unlock_rule">department_champion</field>
            <field name="unlock_value">1</field>
            <field name="rarity">legendary</field>
        </record>

    </data>
</odoo>
