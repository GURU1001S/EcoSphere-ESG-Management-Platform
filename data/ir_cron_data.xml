<odoo>
    <data noupdate="1">

        <record id="ir_cron_recompute_department_scores" model="ir.cron">
            <field name="name">EcoSphere: Recompute Department ESG Scores</field>
            <field name="model_id" ref="model_esg_department_score"/>
            <field name="state">code</field>
            <field name="code">model._cron_recompute_all_scores()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_flag_overdue_acknowledgements" model="ir.cron">
            <field name="name">EcoSphere: Flag Overdue Policy Acknowledgements</field>
            <field name="model_id" ref="model_esg_policy_acknowledgement"/>
            <field name="state">code</field>
            <field name="code">model._cron_flag_overdue()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_flag_overdue_compliance_issues" model="ir.cron">
            <field name="name">EcoSphere: Flag Overdue Compliance Issues</field>
            <field name="model_id" ref="model_esg_compliance_issue"/>
            <field name="state">code</field>
            <field name="code">model._cron_flag_overdue_issues()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="seq_esg_audit" model="ir.sequence">
            <field name="name">ESG Audit Sequence</field>
            <field name="code">esg.audit</field>
            <field name="prefix">AUD/%(year)s/</field>
            <field name="padding">4</field>
        </record>

        <record id="seq_esg_compliance_issue" model="ir.sequence">
            <field name="name">ESG Compliance Issue Sequence</field>
            <field name="code">esg.compliance.issue</field>
            <field name="prefix">CI/%(year)s/</field>
            <field name="padding">4</field>
        </record>

        <record id="seq_carbon_transaction" model="ir.sequence">
            <field name="name">Carbon Transaction Sequence</field>
            <field name="code">carbon.transaction</field>
            <field name="prefix">CAR/%(year)s/</field>
            <field name="padding">4</field>
        </record>

    </data>
</odoo>
