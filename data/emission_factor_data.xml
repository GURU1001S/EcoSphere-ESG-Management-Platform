<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Standard Electricity -->
        <record id="ef_grid_electricity" model="esg.emission.factor">
            <field name="name">Grid Electricity (Standard)</field>
            <field name="factor_value">0.82</field>
            <field name="unit_of_measure">kg CO2e / kWh</field>
        </record>

        <!-- Diesel Fuel -->
        <record id="ef_diesel_generator" model="esg.emission.factor">
            <field name="name">Diesel (Generators)</field>
            <field name="factor_value">2.68</field>
            <field name="unit_of_measure">kg CO2e / Liter</field>
        </record>

        <!-- Commercial Flights -->
        <record id="ef_air_travel" model="esg.emission.factor">
            <field name="name">Air Travel (Commercial)</field>
            <field name="factor_value">0.15</field>
            <field name="unit_of_measure">kg CO2e / km</field>
        </record>

        <record id="ef_office_paper" model="esg.emission.factor">
            <field name="name">Office Paper</field>
            <field name="factor_value">1.30</field>
            <field name="unit_of_measure">kg CO2e / kg</field>
        </record>

        <record id="ef_landfill_waste" model="esg.emission.factor">
            <field name="name">Landfill Waste</field>
            <field name="factor_value">0.45</field>
            <field name="unit_of_measure">kg CO2e / kg</field>
        </record>

        <record id="ef_water_supply" model="esg.emission.factor">
            <field name="name">Water Supply</field>
            <field name="factor_value">0.34</field>
            <field name="unit_of_measure">kg CO2e / cubic meter</field>
        </record>

    </data>
</odoo>
