        <t t-call="web.basic_layout">
            <div class="page">
                <h2>EcoSphere ESG Dashboard</h2>
                <p>Report generated for department: <t t-esc="doc.name"/></p>
                <p>Current score: <t t-esc="doc.score"/></p>
            </div>
        </t>
    </template>
</odoo>
