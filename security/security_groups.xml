<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="group_eco_employee" model="res.groups">
        <field name="name">EcoSphere Employee</field>

    </record>
    <record id="group_eco_approver" model="res.groups">
        <field name="name">EcoSphere Approver</field>

        <field name="implied_ids" eval="[(4, ref('group_eco_employee'))]"/>
    </record>
    <record id="group_eco_admin" model="res.groups">
        <field name="name">EcoSphere Admin</field>

        <field name="implied_ids" eval="[(4, ref('group_eco_approver'))]"/>
    </record>
</odoo>
